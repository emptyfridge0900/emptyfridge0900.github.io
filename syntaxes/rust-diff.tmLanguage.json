{
  "name": "rust-diff",
  "scopeName": "source.rust-diff",
  "fileTypes": ["rust-diff", "rsdiff"],
  "patterns": [
    { "include": "#word-deleted-line" },
    { "include": "source.rust" }
  ],
  "injections": {
    "L:source.rust-diff": {
      "patterns": [
        { "include": "#diff-header" },
        { "include": "#hunk-header" },
        { "include": "#word-inserted" },
        { "include": "#inserted-line" },
        { "include": "#deleted-line" }
      ]
    }
  },
  "repository": {
    "diff-header": {
      "name": "meta.diff.header",
      "match": "^(diff --git|index |--- |\\+\\+\\+ ).*$"
    },
    "hunk-header": {
      "name": "meta.diff.range",
      "match": "^(@@).*$"
    },
    "word-deleted-line": {
      "begin": "^(?=.*\\[-)",
      "end": "$",
      "patterns": [
        { "include": "#word-inserted" },
        { "include": "#word-deleted" }
      ]
    },
    "word-inserted": {
      "match": "(\\{\\+)(.*?)(\\+\\})",
      "captures": {
        "1": {
          "name": "markup.bold markup.italic punctuation.definition.inserted.begin.diff"
        },
        "2": {
          "name": "markup.inserted.diff"
        },
        "3": {
          "name": "markup.bold markup.italic punctuation.definition.inserted.end.diff"
        }
      }
    },
    "word-deleted": {
      "match": "(\\[-)(.*?)(-\\])",
      "captures": {
        "1": {
          "name": "markup.bold markup.italic punctuation.definition.deleted.begin.diff"
        },
        "2": {
          "name": "markup.deleted.diff"
        },
        "3": {
          "name": "markup.bold markup.italic punctuation.definition.deleted.end.diff"
        }
      }
    },
    "inserted-line": {
      "name": "markup.inserted.diff",
      "match": "^(\\+)(?!\\+\\+ )(.*)$",
      "captures": {
        "1": {
          "name": "markup.bold punctuation.definition.inserted.diff"
        }
      }
    },
    "deleted-line": {
      "name": "markup.deleted.diff",
      "match": "^(-)(?!-- )(.*)$",
      "captures": {
        "1": {
          "name": "markup.bold punctuation.definition.deleted.diff"
        }
      }
    }
  }
}
